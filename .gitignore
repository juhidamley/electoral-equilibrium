.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/

# Abstra
# Abstra is an AI-powered process automation framework.
# Ignore directories containing user credentials, local state, and settings.
# Learn more at https://abstra.io/docs
.abstra/

# Visual Studio Code
#  Visual Studio Code specific template is maintained in a separate VisualStudioCode.gitignore 
#  that can be found at https://github.com/github/gitignore/blob/main/Global/VisualStudioCode.gitignore
#  and can be added to the global gitignore or merged into this file. However, if you prefer, 
#  you could uncomment the following to ignore the entire vscode folder
# .vscode/

# Project data directories (large files, not for version control)
data/
artifacts/
# rawdata: ignore large runtime outputs but track documentation and reports
rawdata/social/
rawdata/articles/
rawdata/merged/
rawdata/*.jsonl
rawdata/*.parquet

# Ruff stuff:
.ruff_cache/

# PyPI configuration file
.pypirc

# Cursor
#  Cursor is an AI-powered code editor. `.cursorignore` specifies files/directories to
#  exclude from AI features like autocomplete and code analysis. Recommended for sensitive data
#  refer to https://docs.cursor.com/context/ignore-files
.cursorignore
.cursorindexingignore

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/

# LaTeX — build artifacts only; *.tex source and *.pdf output are tracked
*.aux
*.out
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls
*.nav
*.snm
*.vrb
*.lof
*.lot
*.bbl
*.blg

# ── Credentials — never commit these ──────────────────────────────────────────
# .env is already above; these are additional safeguards
.env.*
!.env.example        # example template is OK to commit
secrets*.json
credentials*.json
service_account*.json
*.pem
*.p12
*.key
configs/*.local.json  # local overrides that may contain API keys or IPs

# ── ML model weights and adapters ─────────────────────────────────────────────
# Model weights belong in HuggingFace Hub or a dedicated model store, not git
*.safetensors
*.bin
*.pt
*.pth
*.gguf
*.ggml
adapters/
# fine-tuned adapters + full checkpoint dirs (HF Hub is source of truth)
models/
# training checkpoints (optimizer state, rng, scheduler)
checkpoints/
.cache/              # HuggingFace model download cache
mlruns/              # MLflow experiment tracking

# ── Pipeline runtime outputs ───────────────────────────────────────────────────
logs/
nohup.out
slurm-*.out          # SLURM job stdout/stderr (HPC)
*.sbatch.log
run_*.log

# ── Local databases ────────────────────────────────────────────────────────────
# DuckDB and SQLite files may contain raw data or audit logs
*.duckdb
*.db
# Note: *.sqlite3 and db.sqlite3 already covered above (Django section)

# ── macOS system files ─────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
._*

# ── Syncthing ──────────────────────────────────────────────────────────────────
.stfolder
.stignore
.stversions/

# ── Next.js webapp (webapp/) ──────────────────────────────────────────────────
# .next/ guards against accidental `next dev` or `next build` run from the repo root
.next/
# webapp/.next/ is also covered by webapp/.gitignore (belt-and-suspenders)
webapp/.next/
webapp/out/              # next export static output
webapp/node_modules/
webapp/.env.local        # local dev overrides (NEXT_PUBLIC_API_URL etc.)
webapp/.env*.local
webapp/tsconfig.tsbuildinfo
webapp/next-env.d.ts     # auto-generated by Next.js — do not edit manually
webapp/.turbo/
webapp/coverage/         # Jest --coverage output

# ── Reddit Devvit app (elec-equilibrium/) ─────────────────────────────────────
# This is a Devvit Reddit platform app that lives alongside the Python pipeline.
# Track source (src/, public/, configs) but not build artifacts or dependencies.
elec-equilibrium/node_modules/
elec-equilibrium/dist/
elec-equilibrium/.devvit/
elec-equilibrium/*.lock

# ── Devlog drafts (published separately at devlog.juhi.studio) ────────────────
devlog/

# ── markdown files ─────────────────────────────────────────
# Markdown files are used for documentation and notes, but may contain sensitive info or be too verbose for version control.
*.md
!DECISIONS.md        # canonical architecture decision log — always track

# ── Docs ─────────────────────────────────────────
#  Documentation may contain generated files, build artifacts, or sensitive info. Track source files but ignore build outputs.
docs/
